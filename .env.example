# All values are optional — defaults are fine for local dev.
# Prefix all env vars with STABLE_

STABLE_HOST=0.0.0.0
STABLE_PORT=8000
STABLE_DEPLOYMENT=local       # local | adl | tacc
STABLE_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
STABLE_TAP_SYNC_TIMEOUT_SECONDS=20.0
STABLE_JOB_TTL_SECONDS=3600
