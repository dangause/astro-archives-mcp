# All values are optional — defaults are fine for local dev.
# Prefix all env vars with STABLE_

STABLE_HOST=0.0.0.0
STABLE_PORT=8000
STABLE_DEPLOYMENT=local       # local | adl | tacc
STABLE_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
STABLE_TAP_SYNC_TIMEOUT_SECONDS=20.0
STABLE_JOB_TTL_SECONDS=3600

# Inline-tier response caps. A tabular result over EITHER limit spills to the
# Parquet Resource tier (resource_uri + 50-row preview) instead of inlining
# every row — keeping tool results from overflowing a small model context.
# Defaults suit a 64K-token backend; raise for frontier models with big windows.
STABLE_INLINE_ROW_LIMIT=200
STABLE_INLINE_BYTE_LIMIT=49152   # 48 * 1024
