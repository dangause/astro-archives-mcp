# Frontend stack config — copy to `.env` and edit. Consumed by docker-compose.yml.

# ── Model backend — pick ONE option; they are mutually exclusive ─────────────
# IMPORTANT: the ANTHROPIC_DEFAULT_*_MODEL overrides are LOCAL-vLLM-ONLY. With
# hosted Claude they make Claude Code request a "Qwen/…" model that Anthropic
# doesn't have → "model may not exist". Keep them commented for Option A.
#
# ── OPTION A: hosted Claude (no vLLM needed; exercise the frontend on its own) ─
#   Leave BASE_URL blank + the *_MODEL lines commented; authenticate with a
#   subscription token (`claude setup-token`) or an API key.
# ANTHROPIC_BASE_URL=
# CLAUDE_CODE_OAUTH_TOKEN=          # from `claude setup-token` (subscription; no API billing)
# ANTHROPIC_API_KEY=               # alt: from console.anthropic.com (needs org credits)
#
# ── OPTION B: dlai01 vLLM via the datalab nginx proxy ── VALIDATED 2026-07-02 ──
#   The vLLM is fronted by Chadd's nginx proxy (public TLS, HTTP Basic auth).
#   Auth rides ENTIRELY in ANTHROPIC_CUSTOM_HEADERS as a base64 `user:pass`.
#
#   ⚠️ Do NOT also set ANTHROPIC_AUTH_TOKEN — Claude Code would send
#      `Authorization: Bearer <token>`, colliding with the `Authorization: Basic`
#      header below, and nginx returns 401. (Bare curl with only the Basic header
#      works; the collision is Claude-Code-specific.) Leave AUTH_TOKEN unset.
ANTHROPIC_BASE_URL=https://datalab.noirlab.edu/astro-archives-mcp
ANTHROPIC_CUSTOM_HEADERS=Authorization: Basic <base64 of user:password from Chadd>
#   REQUIRED for stable sessions: give Claude Code a credential it recognizes, or
#   it intermittently declares "You're not authenticated / run claude /login"
#   mid-session (the Basic header in CUSTOM_HEADERS makes requests work, but Claude
#   Code's own login-state check can't see it). `dummy` rides `x-api-key` — a
#   different header than the Basic `Authorization` — so no collision; vLLM ignores it.
ANTHROPIC_API_KEY=dummy
ANTHROPIC_DEFAULT_OPUS_MODEL=Qwen/Qwen3.5-122B-A10B-FP8
ANTHROPIC_DEFAULT_SONNET_MODEL=Qwen/Qwen3.5-122B-A10B-FP8
ANTHROPIC_DEFAULT_HAIKU_MODEL=Qwen/Qwen3.5-122B-A10B-FP8

# Cap output so it fits the served window (see runbook Gotcha 4).
CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192

# ── Images ───────────────────────────────────────────────────────────────────
FRONTEND_IMAGE=astro-frontend:dev
# chat-mode JupyterLab port. docker-stacks honors this as the IN-container port too,
# and compose maps it 1:1 host↔container. Change if 8888 is already in use locally.
JUPYTER_PORT=8888

# ── Hub mode only ────────────────────────────────────────────────────────────
# Local dev uses a dummy authenticator; set a shared password.
JUPYTERHUB_DUMMY_PASSWORD=changeme
# The docker network the hub attaches spawned single-user containers to.
# Must equal the compose project's network (see README if you rename the project).
DOCKER_NETWORK=frontend_default
