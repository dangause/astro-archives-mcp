# Frontend stack config — copy to `.env` and edit. Consumed by docker-compose.yml.

# ── Model backend — pick ONE option; they are mutually exclusive ─────────────
# IMPORTANT: the ANTHROPIC_DEFAULT_*_MODEL overrides are LOCAL-vLLM-ONLY. With
# hosted Claude they make Claude Code request a "Qwen/…" model that Anthropic
# doesn't have → "model may not exist". Keep them commented for Option A.
#
# ── OPTION A: hosted Claude (test the frontend before dlai01's 443 is open) ──
#   Leave BASE_URL/AUTH_TOKEN blank; authenticate with a subscription token
#   (`claude setup-token`) or an API key. Keep the *_MODEL lines commented.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
# CLAUDE_CODE_OAUTH_TOKEN=          # from `claude setup-token` (subscription; no API billing)
# ANTHROPIC_API_KEY=               # alt: from console.anthropic.com (needs org credits)
#
# ── OPTION B: local dlai01 vLLM (once 443 is open + authenticated) ───────────
#   Set BASE_URL + AUTH_TOKEN (= vLLM's --api-key secret), clear the Option-A
#   creds above, and UNCOMMENT the *_MODEL lines (match vLLM's served name):
#   ANTHROPIC_BASE_URL=https://dlai01.csdc.noirlab.edu
#   ANTHROPIC_AUTH_TOKEN=<the --api-key secret>
# ANTHROPIC_DEFAULT_OPUS_MODEL=Qwen/Qwen3.5-122B-A10B-FP8
# ANTHROPIC_DEFAULT_SONNET_MODEL=Qwen/Qwen3.5-122B-A10B-FP8
# ANTHROPIC_DEFAULT_HAIKU_MODEL=Qwen/Qwen3.5-122B-A10B-FP8

# Cap output so it fits the served window (see runbook Gotcha 4).
CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192

# ── Images ───────────────────────────────────────────────────────────────────
FRONTEND_IMAGE=astro-frontend:dev
# Host port for chat-mode JupyterLab (change if 8888 is already in use locally).
JUPYTER_PORT=8888

# ── Hub mode only ────────────────────────────────────────────────────────────
# Local dev uses a dummy authenticator; set a shared password.
JUPYTERHUB_DUMMY_PASSWORD=changeme
# The docker network the hub attaches spawned single-user containers to.
# Must equal the compose project's network (see README if you rename the project).
DOCKER_NETWORK=frontend_default
